{"ast":null,"code":"import { computed } from 'vue';\nimport { RouterView, useRoute } from 'vue-router';\nimport ErrorBoundary from './components/common/ErrorBoundary.vue';\nimport GlobalStatus from './components/common/GlobalStatus.vue';\nimport AppSidebar from './components/layout/AppSidebar.vue';\nimport AppHeader from './components/layout/AppHeader.vue';\nexport default {\n  __name: 'App',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const route = useRoute();\n    const showLayout = computed(() => !route.meta?.hideLayout);\n    const __returned__ = {\n      route,\n      showLayout,\n      computed,\n      get RouterView() {\n        return RouterView;\n      },\n      get useRoute() {\n        return useRoute;\n      },\n      ErrorBoundary,\n      GlobalStatus,\n      AppSidebar,\n      AppHeader\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","RouterView","useRoute","ErrorBoundary","GlobalStatus","AppSidebar","AppHeader","route","showLayout","meta","hideLayout"],"sources":["D:/Nzs/group_work-master/group_work-main/ecommerce-frontend/src/App.vue"],"sourcesContent":["<template>\n  <div class=\"app-shell\">\n    <AppSidebar v-if=\"showLayout\" />\n    <div class=\"app-main\" :class=\"{ 'with-layout': showLayout }\">\n      <AppHeader v-if=\"showLayout\" class=\"app-header\" />\n      <div class=\"app-content\">\n        <ErrorBoundary>\n          <RouterView v-slot=\"{ Component }\">\n            <Suspense>\n              <component :is=\"Component\" />\n              <template #fallback>\n                <div class=\"suspense-fallback\">\n                  <el-skeleton :rows=\"4\" animated />\n                </div>\n              </template>\n            </Suspense>\n          </RouterView>\n        </ErrorBoundary>\n      </div>\n    </div>\n    <GlobalStatus />\n  </div>\n</template>\n\n<script setup>\nimport { computed } from 'vue';\nimport { RouterView, useRoute } from 'vue-router';\nimport ErrorBoundary from './components/common/ErrorBoundary.vue';\nimport GlobalStatus from './components/common/GlobalStatus.vue';\nimport AppSidebar from './components/layout/AppSidebar.vue';\nimport AppHeader from './components/layout/AppHeader.vue';\n\nconst route = useRoute();\nconst showLayout = computed(() => !route.meta?.hideLayout);\n</script>\n\n<style scoped>\n.app-shell {\n  min-height: 100vh;\n  background: #f3f4f6;\n  color: #111827;\n  display: flex;\n  font-size: clamp(14px, 1.8vw, 16px);\n}\n\n.app-main {\n  flex: 1;\n  padding-right: 12px;\n}\n\n.app-main.with-layout {\n  margin-left: 12px;\n}\n\n.app-header {\n  position: sticky;\n  top: 0;\n  z-index: 10;\n  background: rgba(255, 255, 255, 0.92);\n  backdrop-filter: blur(6px);\n  border-bottom: 1px solid #e5e7eb;\n}\n\n.app-content {\n  padding: 24px;\n}\n\n.suspense-fallback {\n  padding: 24px;\n}\n</style>\n\n"],"mappings":"AAyBA,SAASA,QAAQ,QAAQ,KAAK;AAC9B,SAASC,UAAU,EAAEC,QAAQ,QAAQ,YAAY;AACjD,OAAOC,aAAa,MAAM,uCAAuC;AACjE,OAAOC,YAAY,MAAM,sCAAsC;AAC/D,OAAOC,UAAU,MAAM,oCAAoC;AAC3D,OAAOC,SAAS,MAAM,mCAAmC;;;;;;;IAEzD,MAAMC,KAAK,GAAGL,QAAQ,CAAC,CAAC;IACxB,MAAMM,UAAU,GAAGR,QAAQ,CAAC,MAAM,CAACO,KAAK,CAACE,IAAI,EAAEC,UAAU,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}